# ── Groq LLM (Recipe AI) ──────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── YOLO Ingredient Detection (RecipeMaker-AI) ────────────────────────────────
# Path to a custom YOLO model file (.pt). Defaults to yolov8n.pt (auto-downloaded).
# For better food detection, use a food-trained model, e.g.:
#   https://huggingface.co/arnabdhar/YOLOv8-nano-food
YOLO_MODEL_PATH=yolov8n.pt

# ── App Config ────────────────────────────────────────────────────────────────
DEBUG=True
